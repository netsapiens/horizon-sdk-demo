# Copy to `.env` and fill in. The example loads it via `node --env-file=.env`
# (Node 20+) or your process manager; see README.

# Port the callback server listens on.
PORT=8787

# The path your `callbackUrl` points at. Must match what you registered as the
# app's allowed callback hostname + this path, e.g.
# https://your-host:8787/horizon/callback
CALLBACK_PATH=/horizon/callback

# Per-app shared secret, set in Horizon admin (Registered Apps → remote auth).
# Used to verify the X-NS-Signature HMAC.
HORIZON_CALLBACK_SECRET=replace-with-the-secret-from-registered-apps

# Your app id, as registered in Horizon. The cluster-verification JWT's `appId`
# claim must match this.
HORIZON_APP_ID=horizon-extension-demo

# INSight JWKS endpoint used to verify the X-NS-Cluster-Verification JWT.
# Operators on beta/dev may publish a different host.
INSIGHT_JWKS_URL=https://insight.netsapiens.com/.well-known/jwks.json
INSIGHT_ISSUER=https://insight.netsapiens.com

# Secret used to sign the vendor's OWN tokens (this is your token, not NS's).
VENDOR_JWT_SECRET=replace-with-a-long-random-string
VENDOR_TOKEN_TTL_SECONDS=3600

# MOCK_MODE=1 skips the cluster-JWT verification and the live code exchange so
# you can smoke-test signature verification + response shaping locally with no
# NetSapiens cluster. NEVER set this in production.
MOCK_MODE=0
