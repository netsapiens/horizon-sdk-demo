# @netsapiens/horizon-sdk is published to npm with restricted (private) access.
# Installing it requires authentication to the npm registry:
#   - Local dev: log in once with `npm login` (writes a token to ~/.npmrc), or
#     export NPM_TOKEN and uncomment the auth line below.
#   - CI: the GitHub Actions workflow injects the token from the NPM_TOKEN secret.
@netsapiens:registry=https://registry.npmjs.org/

# //registry.npmjs.org/:_authToken=${NPM_TOKEN}
